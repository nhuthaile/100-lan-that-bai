---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={`Nhật ký — ${SITE_TITLE}`} description="Tất cả bài viết về hành trình 100 lần thất bại." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Nhật ký hành trình</h1>
				<p>Mỗi bài viết là một lần thử, một lần học, một bước tiến.</p>
			</div>

			{posts.length === 0 ? (
				<div class="empty-state">
					<p>🚀 Bài viết đầu tiên sắp ra mắt...</p>
				</div>
			) : (
				<ul class="post-list">
					{posts.map((post) => (
						<li class="post-item">
							<a href={`/blog/${post.id}/`}>
								<div class="post-meta">
									{post.data.startupNumber && (
										<span class="startup-number">#{String(post.data.startupNumber).padStart(3, '0')}</span>
									)}
									{post.data.status && (
										<span class={`status status-${post.data.status}`}>{post.data.status}</span>
									)}
									{post.data.type !== 'general' && (
										<span class="post-type">{post.data.type}</span>
									)}
									<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
								</div>
								<h3 class="post-title">{post.data.title}</h3>
								<p class="post-desc">{post.data.description}</p>
								{post.data.lesson && (
									<p class="post-lesson">💡 {post.data.lesson}</p>
								)}
								{post.data.techStack && (
									<div class="tech-tags">
										{post.data.techStack.map(tech => (
											<span class="tech-tag">{tech}</span>
										))}
									</div>
								)}
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border);
	}
	.page-header h1 {
		font-family: var(--font-body), sans-serif;
		margin-bottom: 0.5rem;
	}
	.page-header p {
		color: var(--text-muted);
		font-size: 1rem;
		margin: 0;
	}
	.empty-state {
		padding: 4rem;
		text-align: center;
		border: 1px dashed var(--border);
		border-radius: 8px;
		color: var(--text-dim);
	}
	.post-list {
		list-style: none;
		padding: 0;
	}
	.post-item {
		border-bottom: 1px solid var(--border);
	}
	.post-item a {
		display: block;
		padding: 1.5rem 0;
		text-decoration: none;
		transition: all 0.15s;
	}
	.post-item a:hover {
		background: var(--bg-surface);
		margin: 0 -1rem;
		padding: 1.5rem 1rem;
		border-radius: 8px;
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.5rem;
		flex-wrap: wrap;
	}
	.post-date {
		font-size: 0.8rem;
		color: var(--text-dim);
		font-family: var(--font-mono), monospace;
	}
	.post-type {
		font-family: var(--font-mono), monospace;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-dim);
		background: var(--bg-elevated);
		padding: 2px 8px;
		border-radius: 3px;
		border: 1px solid var(--border);
	}
	.post-title {
		font-family: var(--font-body), sans-serif;
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 0.4rem;
		line-height: 1.4;
	}
	.post-desc {
		font-size: 0.95rem;
		color: var(--text-muted);
		margin-bottom: 0;
	}
	.post-lesson {
		font-size: 0.85rem;
		color: var(--accent);
		margin-top: 0.5rem;
		margin-bottom: 0;
		font-style: italic;
	}
	.tech-tags {
		display: flex;
		gap: 0.4rem;
		margin-top: 0.6rem;
		flex-wrap: wrap;
	}
	.tech-tag {
		font-family: var(--font-mono), monospace;
		font-size: 0.7rem;
		color: var(--text-dim);
		background: var(--bg-elevated);
		padding: 2px 8px;
		border-radius: 3px;
		border: 1px solid var(--border);
	}
</style>
